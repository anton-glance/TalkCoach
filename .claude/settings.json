{
  "permissions": {
    "allow": [
      "Bash(xcodebuild:*)",
      "Bash(swiftlint:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "if command -v swiftlint >/dev/null 2>&1; then swiftlint --quiet 2>&1 | head -30; fi"
      }
    ]
  }
}
